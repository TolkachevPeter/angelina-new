# ---- Runtime ----
NODE_ENV=production
PORT=4280

# Set true ONLY when a trusted reverse proxy (nginx / cloud LB) sits in front and
# overwrites X-Forwarded-For — this lets the real client IP drive rate limiting.
# Leave false for direct exposure, otherwise clients can spoof the header.
TRUST_PROXY=false

# ---- SEO / branding (IMPORTANT: set these for production) ----
# Canonical origin — drives <link rel=canonical>, Open Graph URLs, JSON-LD and the sitemap.
SITE_URL=https://angelinabelokon.com
# Contact address shown on the page and embedded in structured data.
CONTACT_EMAIL=hello@angelinabelokon.com
# Comma-separated social / profile links used for schema.org sameAs.
SOCIAL_LINKS=https://instagram.com/ang.belokon,https://ounce.agency
# Optional overrides (sensible defaults exist):
# SITE_NAME=Angelina Belokon
# SITE_TITLE=Angelina Belokon — Art Director & Creative Consultant for Fashion Brands
# SITE_DESCRIPTION=Art direction, styling and creative consulting for fashion & lifestyle brands.
# SITE_LOCALE=en_US
# Default paper theme (visitors can switch): paper | ivory | pearl | powder | sand
SITE_THEME=ivory
# TWITTER_HANDLE=@ang.belokon
# Stable sitemap <lastmod> (YYYY-MM-DD). Defaults to the landing template's mtime.
# SITE_LASTMOD=2026-07-15

# ---- Leads ----
LEADS_PATH=./data/leads.json

# ---- Security / limits ----
# CORS is only enabled if set (comma-separated origins).
# CORS_ORIGIN=https://angelinabelokon.com
# Contact-form rate limit: THROTTLE_LIMIT requests per THROTTLE_TTL seconds per IP.
THROTTLE_TTL=60
THROTTLE_LIMIT=5
